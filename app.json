{
  "expo": {
    "name": "walter",
    "slug": "walter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Walter benötigt das Mikrofon, um Aufträge per Sprache zu erstellen.",
        "NSSpeechRecognitionUsageDescription": "Walter verwendet Spracherkennung, um deine Beschreibung in einen Auftrag umzuwandeln.",
        "NSPhotoLibraryUsageDescription": "Walter speichert Fotos zu deinen Aufträgen.",
        "NSCameraUsageDescription": "Walter verwendet die Kamera, um Fotos zu Aufträgen hinzuzufügen."
      },
      "bundleIdentifier": "com.anonymous.walter"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.walter"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "walter",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-speech-recognition",
      "expo-image-picker"
    ]
  }
}
